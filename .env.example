# ================================================================
# Piggybank Planner — Variáveis de Ambiente
# ================================================================
# ATENÇÃO: Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env — apenas este .env.example
# ================================================================

# Supabase (Frontend) — obtenha em https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL="https://SEU-PROJECT-ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."
VITE_SUPABASE_PROJECT_ID="SEU-PROJECT-ID"

# ── Segredos de Servidor (NÃO precisam estar aqui) ─────────────
# Os segredos abaixo são armazenados na tabela public.secrets do Supabase.
# Configure-os via SQL no painel do Supabase, nunca aqui:
#
#   GEMINI_API_KEY            → chave do Google AI Studio
#   WHATSAPP_API_TOKEN        → token permanente da Meta
#   WHATSAPP_PHONE_NUMBER_ID  → ID do número no Meta
#   WHATSAPP_VERIFY_TOKEN     → token de verificação do webhook
#   WHATSAPP_ALLOWED_NUMBERS  → números autorizados (ex: 5511999999999)
